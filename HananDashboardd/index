    function saveDriver() {
        const name = document.getElementById('dName').value;
        const truck = document.getElementById('dTruck').value;
        const phone = document.getElementById('dPhone').value;
        const idx = document.getElementById('editIdx').value;

        if (!name) { alert("Please enter a driver name"); return; }

        if (idx === "-1") {
            drivers.push({ name, truck, phone });
        } else {
            drivers[idx] = { name, truck, phone };
            document.getElementById('editIdx').value = "-1";
        }
        
        // Clear the form inputs
        document.getElementById('dName').value = '';
        document.getElementById('dTruck').value = '';
        document.getElementById('dPhone').value = '';
        
        renderDrivers();
    }

    function editDriver(index) {
        document.getElementById('dName').value = drivers[index].name;
        document.getElementById('dTruck').value = drivers[index].truck;
        document.getElementById('dPhone').value = drivers[index].phone;
        document.getElementById('editIdx').value = index;
    }

    function deleteDriver(index) {
        if(confirm('Are you sure you want to remove this driver?')) {
            drivers.splice(index, 1);
            renderDrivers();
        }
    }

    // Initialize the list on load
    renderDrivers();
